# ── Docker Environment ──────────────────────────────────────
# Copy this file to .env and adjust values as needed
#
#   cp .env.example .env
#
# ── App ─────────────────────────────────────────────────────
APP_PORT=8080

# ── Database ────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_NAME=wilayah
DB_USER=wilayah
DB_PASS=wilayah
DB_CHARSET=utf8mb4
MYSQL_ROOT_PASSWORD=secret

# ── phpMyAdmin ──────────────────────────────────────────────
PMA_PORT=8888
